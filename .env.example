# Credenciais do Postgres (Docker). Copie para .env e ajuste se quiser.
POSTGRES_USER=carona
POSTGRES_PASSWORD=carona_dev_2026
POSTGRES_DB=app_carona

# Porta exposta no host para o Postgres do container (5432 já é usada por outro Postgres local).
POSTGRES_HOST_PORT=55432

# E-mail do master principal (quem pode promover outros usuários a master).
MASTER_EMAIL=seu-email@empresa.com

# Obs: variáveis do frontend (VITE_*) ficam em frontend/.env — ver frontend/.env.example.

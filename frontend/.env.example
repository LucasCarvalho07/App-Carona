# Variáveis do frontend (Vite). Copie para frontend/.env e preencha.
# ATENÇÃO: tudo com prefixo VITE_ é PÚBLICO (vai embutido no bundle do navegador).
# Nunca coloque segredos aqui — apenas valores públicos por natureza (ex.: Client ID do Google).

# Client ID do Google OAuth (login com Google). Pegue no Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Base da API. Em dev deixe VAZIO (usa o proxy /api do Vite).
# Em produção (Cloudflare Pages), aponte para a API no Render, incluindo /api:
# VITE_API_URL=https://app-carona-api.onrender.com/api
VITE_API_URL=
